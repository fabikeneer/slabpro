# En producción (Vercel): URL del API en Render, sin barra final
# VITE_API_URL=https://slabpro-api.onrender.com
#
# iOS/Safari: con VITE_API_URL apuntando a Render, las cookies cross-site fallan;
# la app guarda el JWT en localStorage y lo envía como Bearer (no requiere cambio extra).

# En local: dejar vacío; Vite hace proxy de /api → localhost:3001
