# MySQL (local Laragon o TiDB Cloud / Railway)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=slabpro_bd
DB_PORT=3306
# TiDB Cloud (Render): puerto 4000 y TLS obligatorio
# DB_SSL=true
# Si falla SSL en Render, prueba temporalmente: DB_SSL_REJECT_UNAUTHORIZED=false

PORT=3001

# Obligatorio en producción (mín. 32 caracteres aleatorios)
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

# URL del frontend en Vercel (sin barra final). Varias: separadas por coma
CORS_ORIGIN=http://localhost:5173

# Opcional — recuperación de contraseña por correo
# SMTP_USER=
# SMTP_PASS=
