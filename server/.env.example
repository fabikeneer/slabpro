# ═══════════════════════════════════════════════════════════════════
# SlabPro — Variables de entorno (plantilla)
# Copia a server/.env en local. NO subas .env a Git.
# En Render: pegar cada KEY/VALUE en Environment (no usar archivo .env).
# ═══════════════════════════════════════════════════════════════════

# ── Local (Laragon / XAMPP) ───────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=slabpro_bd
DB_PORT=3306

PORT=3001

# Inventas tú esta clave (mín. 32 caracteres). Misma idea en Render.
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

CORS_ORIGIN=http://localhost:5173

# ── Redis (opcional — caché en memoria) ─────────────────────────────
# Sin REDIS_URL la app usa solo MySQL (funciona igual).
# VPS Ubuntu: apt install redis-server → redis://127.0.0.1:6379
# Con contraseña: redis://:TU_PASSWORD@127.0.0.1:6379
# REDIS_URL=redis://127.0.0.1:6379

# ── Producción Render + TiDB Cloud (ejemplo de valores) ─────────────
# DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
# DB_PORT=4000
# DB_USER=xxxxx.root
# DB_PASSWORD=contraseña_desde_tidb_connect
# DB_NAME=slabpro_bd
# DB_SSL=true
# JWT_SECRET=otra_clave_larga_solo_en_render
# CORS_ORIGIN=https://tu-app.vercel.app
# DB_SSL_REJECT_UNAUTHORIZED=false   # solo si falla SSL al conectar

# ── Frontend Vercel (en Vercel, no en server/.env) ─────────────────
# VITE_API_URL=https://tu-api.onrender.com

# ── Opcional — recuperación de contraseña por correo ──────────────
# SMTP_USER=
# SMTP_PASS=
